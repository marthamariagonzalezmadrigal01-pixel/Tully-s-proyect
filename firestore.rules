rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: lectura pública (para buscar email por CURP en login)
    // Escritura solo del propio usuario autenticado
    match /usuarios/{uid} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Trámites: solo el dueño puede leer y escribir
    match /tramites/{tid} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create:       if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update:       if request.auth != null && request.auth.uid == resource.data.uid;
    }
  }
}
